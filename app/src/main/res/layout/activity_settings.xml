<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1117">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:gravity="center_vertical" android:background="#1A1D2B">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless" android:tint="#4F8EF7"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="⚙️ Settings"
            android:textSize="18sp" android:textStyle="bold"
            android:textColor="#E8EAED" android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Security Section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SECURITY" android:textColor="#4F8EF7"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" android:layout_marginTop="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardBackgroundColor="#1C1E2A"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Biometric -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp"
                        android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="👆 Fingerprint / Face" android:textColor="#E8EAED" android:textSize="15sp"/>
                            <TextView android:id="@+id/tvBiometricDesc"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Use biometric to unlock" android:textColor="#8A8FA8" android:textSize="12sp"/>
                        </LinearLayout>
                        <Switch android:id="@+id/switchBiometric"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:thumbTint="#4F8EF7" android:trackTint="#1A2D4A"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2D3A"/>

                    <!-- Change PIN -->
                    <LinearLayout android:id="@+id/layoutChangePin"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp"
                        android:gravity="center_vertical" android:background="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔑 Change PIN" android:textColor="#E8EAED" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Update your 4-digit PIN" android:textColor="#8A8FA8" android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="#4F8EF7" android:textSize="20sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2D3A"/>

                    <!-- Auto Lock -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp"
                        android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="⏱️ Auto Lock" android:textColor="#E8EAED" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Lock app after inactivity" android:textColor="#8A8FA8" android:textSize="12sp"/>
                        </LinearLayout>
                        <Spinner android:id="@+id/spinnerAutoLock"
                            android:layout_width="130dp" android:layout_height="36dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Backup Section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BACKUP &amp; RESTORE" android:textColor="#4F8EF7"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" android:layout_marginTop="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardBackgroundColor="#1C1E2A"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Backup -->
                    <LinearLayout android:id="@+id/layoutBackup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="16dp"
                        android:gravity="center_vertical" android:background="?attr/selectableItemBackground">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💾 Backup to Storage" android:textColor="#E8EAED" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Save to Documents/VaultPro/" android:textColor="#8A8FA8" android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="#4F8EF7" android:textSize="20sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2D3A"/>

                    <!-- Restore -->
                    <LinearLayout android:id="@+id/layoutRestore"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📂 Restore Backup" android:textColor="#E8EAED" android:textSize="15sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Enter path to backup file" android:textColor="#8A8FA8" android:textSize="12sp"/>
                            </LinearLayout>
                        </LinearLayout>
                        <EditText android:id="@+id/etRestorePath"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:hint="/sdcard/Documents/VaultPro/backup.json"
                            android:textColorHint="#8A8FA8" android:textColor="#E8EAED"
                            android:textSize="12sp" android:background="@drawable/input_bg"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:layout_marginBottom="10dp"/>
                        <Button android:id="@+id/btnRestore"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:text="Restore" android:backgroundTint="#22C55E"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
